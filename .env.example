# ==========================================
# S FUTURE AI - Environment Configuration
# ==========================================

# Server
PORT=3000
NODE_ENV=production
SESSION_SECRET=your_super_secret_session_key_change_this_to_random_32_chars

# MongoDB Atlas (Get from mongodb.com → Database → Connect → Drivers → Node.js)
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/sfutureai?retryWrites=true&w=majority

# Google Gemini API (Get from makersuite.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
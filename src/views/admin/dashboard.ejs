<div class="admin-header">
    <h2><i class="fas fa-user-shield"></i> Admin Dashboard</h2>
    <p>Platform overview and management</p>
</div>

<div class="grid grid-4" style="margin-bottom: 30px;">
    <div class="card stat-card admin-stat">
        <div class="stat-value" style="color: var(--admin-primary);"><%= stats.totalUsers %></div>
        <div class="stat-label">Total Users</div>
    </div>
    <div class="card stat-card admin-stat">
        <div class="stat-value" style="color: var(--admin-primary);"><%= stats.totalChats %></div>
        <div class="stat-label">Total Messages</div>
    </div>
    <div class="card stat-card admin-stat">
        <div class="stat-value" style="color: var(--admin-primary);"><%= stats.totalFiles %></div>
        <div class="stat-label">Files Stored</div>
    </div>
    <div class="card stat-card admin-stat">
        <div class="stat-value" style="color: var(--admin-primary);"><%= stats.diamondUsers %></div>
        <div class="stat-label">Diamond Users</div>
    </div>
</div>

<div class="grid grid-2">
    <div class="card admin-card">
        <h3 style="margin-bottom: 20px; color: var(--admin-primary);"><i class="fas fa-chart-pie"></i> Plan Distribution</h3>
        <div style="display: flex; gap: 20px; margin-bottom: 20px;">
            <div style="text-align: center; flex: 1; padding: 20px; background: #f3f4f6; border-radius: 10px; border: 2px solid #d1d5db;">
                <div style="font-size: 28px; font-weight: 700; color: #6b7280;"><%= stats.freeUsers %></div>
                <div style="font-size: 12px; color: var(--gray);">Free</div>
            </div>
            <div style="text-align: center; flex: 1; padding: 20px; background: #fffbeb; border-radius: 10px; border: 2px solid #fbbf24;">
                <div style="font-size: 28px; font-weight: 700; color: #d97706;"><%= stats.goldUsers %></div>
                <div style="font-size: 12px; color: var(--gray);">Gold</div>
            </div>
            <div style="text-align: center; flex: 1; padding: 20px; background: #fef2f2; border-radius: 10px; border: 2px solid #f87171;">
                <div style="font-size: 28px; font-weight: 700; color: #dc2626;"><%= stats.diamondUsers %></div>
                <div style="font-size: 12px; color: var(--gray);">Diamond</div>
            </div>
        </div>
    </div>
    
    <div class="card admin-card">
        <h3 style="margin-bottom: 20px; color: var(--admin-primary);"><i class="fas fa-users"></i> Recent Users</h3>
        <table class="admin-table">
            <thead>
                <tr>
                    <th>User</th>
                    <th>Plan</th>
                    <th>Joined</th>
                </tr>
            </thead>
            <tbody>
                <% recentUsers.forEach(u => { %>
                <tr>
                    <td>
                        <div style="font-weight: 500;"><%= u.username %></div>
                        <div style="font-size: 12px; color: var(--gray);"><%= u.email %></div>
                    </td>
                    <td><span class="badge badge-<%= u.plan %>"><%= u.plan %></span></td>
                    <td><%= new Date(u.createdAt).toLocaleDateString() %></td>
                </tr>
                <% }) %>
            </tbody>
        </table>
        <a href="/admin/users" class="btn admin-btn" style="margin-top: 16px; width: 100%; justify-content: center;">View All Users</a>
    </div>
</div>
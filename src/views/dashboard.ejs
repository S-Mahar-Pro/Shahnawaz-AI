<h2>Dashboard</h2>
<div class="grid grid-3" style="margin-bottom: 30px;">
    <div class="card stat-card">
        <div class="stat-value"><%= recentChats.length %></div>
        <div class="stat-label">Total Chats</div>
    </div>
    <div class="card stat-card">
        <div class="stat-value"><%= user.plan.toUpperCase() %></div>
        <div class="stat-label">Current Plan</div>
    </div>
    <div class="card stat-card">
        <div class="stat-value"><%= user.credits || 0 %></div>
        <div class="stat-label">Credits</div>
    </div>
</div>
<div class="card">
    <h3>Recent Chats</h3>
    <% if (recentChats.length > 0) { %>
        <ul style="list-style: none;">
            <% recentChats.forEach(chat => { %>
                <li style="padding: 10px 0; border-bottom: 1px solid #e2e8f0;">
                    <%= chat.title || 'Untitled Chat' %>
                </li>
            <% }) %>
        </ul>
    <% } else { %>
        <p>No chats yet. <a href="/chat">Start a new chat</a></p>
    <% } %>
</div>
<div style="margin-top: 30px; padding: 20px; background: #f8fafc; border-radius: 10px;">
    <h3>⚡ Quick Access</h3>

    <div style="margin-top: 10px; display: flex; flex-direction: column; gap: 10px;">

        <a href="/chat" style="text-decoration:none;">💬 Chat AI</a>

        <a href="/tools" style="text-decoration:none;">🧠 AI Tools</a>

        <a href="/vault" style="text-decoration:none;">🔒 Vault</a>

        <!-- 👑 ONLY ADMIN BUTTON -->
        <% if (user.role === 'admin') { %>
            <a href="/admin" style="text-decoration:none; color:red;">
                👑 Admin Panel
            </a>
        <% } %>

    </div>
</div>

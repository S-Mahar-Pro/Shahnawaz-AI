<h2>Upgrade Your Plan</h2>
<div class="grid grid-3">
    <div class="plan-card plan-free">
        <h3>Free</h3>
        <div class="plan-price">$0</div>
        <button class="btn btn-secondary" style="width: 100%; justify-content: center;">Current Plan</button>
    </div>
    <div class="plan-card plan-gold">
        <h3>Gold</h3>
        <div class="plan-price">$9.99</div>
        <button class="btn btn-primary" style="width: 100%; justify-content: center;">Upgrade</button>
    </div>
    <div class="plan-card plan-diamond">
        <h3>Diamond</h3>
        <div class="plan-price">$19.99</div>
        <button class="btn btn-primary" style="width: 100%; justify-content: center;">Upgrade</button>
    </div>
</div>
